{
  "name": "@qubesai/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Qubes protocol — sovereign AI agents with cryptographic identity on Bitcoin Cash",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto/index.mjs",
      "require": "./dist/crypto/index.cjs",
      "types": "./dist/crypto/index.d.ts"
    },
    "./wallet": {
      "import": "./dist/wallet/index.mjs",
      "require": "./dist/wallet/index.cjs",
      "types": "./dist/wallet/index.d.ts"
    },
    "./blocks": {
      "import": "./dist/blocks/index.mjs",
      "require": "./dist/blocks/index.cjs",
      "types": "./dist/blocks/index.d.ts"
    },
    "./covenant": {
      "import": "./dist/covenant/index.mjs",
      "require": "./dist/covenant/index.cjs",
      "types": "./dist/covenant/index.d.ts"
    },
    "./package": {
      "import": "./dist/package/index.mjs",
      "require": "./dist/package/index.cjs",
      "types": "./dist/package/index.d.ts"
    },
    "./bcmr": {
      "import": "./dist/bcmr/index.mjs",
      "require": "./dist/bcmr/index.cjs",
      "types": "./dist/bcmr/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/index.mjs",
      "require": "./dist/storage/index.cjs",
      "types": "./dist/storage/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/secp256k1": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "fflate": "^0.8.2"
  },
  "peerDependencies": {
    "cashscript": "^0.12.0",
    "@bitauth/libauth": "^3.1.0"
  },
  "peerDependenciesMeta": {
    "cashscript": {
      "optional": true
    },
    "@bitauth/libauth": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsup": "^8.0.0"
  },
  "keywords": [
    "qubes",
    "bitcoin-cash",
    "bch",
    "nft",
    "cashtokens",
    "ai-agents",
    "sovereign-ai",
    "sdk",
    "cashscript",
    "walletconnect"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BitFaced2/qubes.git",
    "directory": "sdk"
  }
}
