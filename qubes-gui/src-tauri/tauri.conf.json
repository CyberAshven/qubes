{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qubes",
  "version": "0.9.5",
  "identifier": "cash.qube.app",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BitFaced2/Qubes/releases/latest/download/latest.json",
        "https://qube.cash/releases/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxNTUwNjYyMkY5RTI1NzgKUldSNEpaNHZZZ1pWa1VLaDRBK0x1OHBWdmFjVWIxbDlWMHBhd3hYNW04QzVTbHM0dFhSaHNJbTMK"
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "title": "Qubes",
        "url": "/splashscreen.html",
        "width": 700,
        "height": 520,
        "center": true,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "main",
        "title": "Qubes",
        "width": 1400,
        "height": 900,
        "visible": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost https:; media-src 'self' data: blob: asset: http://asset.localhost; connect-src 'self' https: wss:; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/**", "$RESOURCE/**", "**"],
          "deny": ["$HOME/.ssh/**", "$HOME/.gnupg/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/qubes-backend"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/128x128.png",
        "sidebarImage": "icons/icon.png"
      }
    }
  }
}
