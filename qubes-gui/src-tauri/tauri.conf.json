{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qubes",
  "version": "0.1.8",
  "identifier": "com.bitfaced.qubes",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://qube.cash/releases/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxNTUwNjYyMkY5RTI1NzgKUldSNEpaNHZZZ1pWa1VLaDRBK0x1OHBWdmFjVWIxbDlWMHBhd3hYNW04QzVTbHM0dFhSaHNJbTMK"
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "title": "Qubes",
        "url": "/splashscreen.html",
        "width": 600,
        "height": 400,
        "center": true,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "main",
        "title": "Qubes - AI Identity & Memory System",
        "width": 1400,
        "height": 900,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/qubes-backend"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/128x128.png",
        "sidebarImage": "icons/icon.png"
      }
    }
  }
}
